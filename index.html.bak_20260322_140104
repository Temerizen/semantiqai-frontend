async function startStreaming(){
  const message = document.getElementById('streamMessage').value.trim();
  if (!message) return;
  const out = document.getElementById('streamOutput');
  out.textContent = '';

  const presetEl = document.getElementById('chatPreset');
  const preset_key = presetEl ? presetEl.value : '';

  const res = await fetch('/stream-chat', {
    method: 'POST',
    headers: API.headers(),
    body: JSON.stringify({
      message,
      thread_id: currentThreadId,
      preset_key
    })
  });

  if (!res.ok || !res.body) {
    const text = await res.text();
    out.textContent = text || 'Streaming failed.';
    return;
  }

  const contentType = (res.headers.get('content-type') || '').toLowerCase();

  if (!contentType.includes('text/event-stream')) {
    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      out.textContent += decoder.decode(value, { stream: true });
    }
    if (typeof openThread === 'function' && currentThreadId) {
      await openThread(currentThreadId);
    }
    return;
  }

  const reader = res.body.getReader();
  const decoder = new TextDecoder();
  let buffer = '';

  function processEventBlock(block){
    const lines = block.split('\n');
    let eventName = 'message';
    let data = '';
    for (const line of lines) {
      if (line.startsWith('event:')) eventName = line.slice(6).trim();
      if (line.startsWith('data:')) data += line.slice(5).trim();
    }
    if (!data) return;
    try {
      const parsed = JSON.parse(data);
      if (eventName === 'token' && parsed.token) {
        out.textContent += parsed.token;
      }
    } catch (e) {
      if (eventName === 'token') out.textContent += data;
    }
  }

  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    buffer += decoder.decode(value, { stream: true });

    let idx;
    while ((idx = buffer.indexOf('\n\n')) !== -1) {
      const block = buffer.slice(0, idx);
      buffer = buffer.slice(idx + 2);
      processEventBlock(block);
    }
  }

  if (buffer.trim()) processEventBlock(buffer);

  if (typeof openThread === 'function' && currentThreadId) {
    await openThread(currentThreadId);
  }
}

