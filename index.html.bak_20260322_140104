<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SemantiqAI Ascension Agent Council</title>
  <meta name="description" content="SemantiqAI Ascension with multi-agent orchestration, onboarding, presets, threads, founder analytics, and artifact workflows." />
  <style>
    :root{
      --bg:#07101d;
      --bg2:#0d1730;
      --panel:#101936;
      --panel2:#17244c;
      --line:#27376a;
      --text:#eef3ff;
      --muted:#aab7de;
      --accent:#7c9cff;
      --accent2:#5eead4;
      --ok:#8ef7a3;
      --warn:#ffd166;
      --danger:#ff6b81;
      --shadow:0 24px 80px rgba(0,0,0,.35);
      --radius:22px;
    }
    *{box-sizing:border-box}
    html,body{margin:0;padding:0;background:
      radial-gradient(circle at top left, rgba(124,156,255,.14), transparent 28%),
      radial-gradient(circle at top right, rgba(94,234,212,.08), transparent 24%),
      linear-gradient(180deg,#07101d 0%, #0b1327 100%);
      color:var(--text);font-family:Inter,Segoe UI,Arial,sans-serif}
    body{min-height:100vh}
    .shell{max-width:1600px;margin:0 auto;padding:18px}
    .topbar{
      position:sticky;top:12px;z-index:50;
      display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;
      padding:16px 18px;border:1px solid var(--line);border-radius:24px;
      background:rgba(12,18,39,.84);backdrop-filter:blur(12px);box-shadow:var(--shadow)
    }
    .brand{display:flex;gap:12px;align-items:center}
    .logo{
      width:46px;height:46px;border-radius:14px;background:linear-gradient(135deg,#7c9cff,#5eead4);
      display:grid;place-items:center;font-weight:900;color:#08111f
    }
    .brand h1{margin:0;font-size:20px}
    .brand p{margin:3px 0 0;color:var(--muted);font-size:12px}
    .pill{padding:8px 12px;border-radius:999px;border:1px solid var(--line);background:#0e1733;color:var(--muted);font-size:12px}
    .layout{display:grid;grid-template-columns:300px 1fr 360px;gap:16px;margin-top:16px}
    .card{
      background:linear-gradient(180deg, rgba(17,25,54,.96), rgba(11,18,37,.96));
      border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)
    }
    .card .inner{padding:18px}
    .stack{display:grid;gap:12px}
    input,textarea,button,select{
      width:100%;padding:12px 14px;border-radius:16px;border:1px solid var(--line);
      background:#0b1430;color:var(--text);font:inherit
    }
    textarea{min-height:120px;resize:vertical}
    button{cursor:pointer}
    .primary{background:linear-gradient(135deg,var(--accent),#6c7fff);border-color:#90a2ff}
    .secondary{background:#121c3d}
    .danger{background:linear-gradient(135deg,#ff6b81,#ff4d6d);border-color:#ff7f92}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .hero{
      padding:24px;border-bottom:1px solid var(--line);
      background:radial-gradient(circle at top right, rgba(124,156,255,.18), transparent 35%)
    }
    .hero h2{margin:0 0 10px;font-size:32px;line-height:1.08}
    .hero p{margin:0;color:var(--muted);line-height:1.6}
    .module-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:16px}
    .mini{padding:12px;border:1px solid var(--line);border-radius:16px;background:#0d1730}
    .tabs{display:flex;gap:8px;flex-wrap:wrap;padding:16px 18px;border-bottom:1px solid var(--line)}
    .tab{width:auto;padding:10px 14px;border-radius:999px;background:#0f1731;border:1px solid var(--line);color:var(--muted)}
    .tab.active{background:linear-gradient(135deg,#1d2b5d,#16224a);color:var(--text);border-color:#7c9cff}
    .panel{display:none;padding:18px}
    .panel.active{display:block}
    .thread-list,.list,.chat-log,.starter-grid{
      border:1px solid var(--line);border-radius:18px;background:#091126;padding:10px
    }
    .thread-list,.list{display:grid;gap:10px;max-height:420px;overflow:auto}
    .starter-grid{display:grid;gap:10px}
    .chat-log{display:grid;gap:12px;min-height:420px;max-height:560px;overflow:auto}
    .thread-item,.item,.msg,.starter{
      padding:12px;border:1px solid var(--line);border-radius:16px;background:#0d1730
    }
    .thread-item.active{outline:2px solid #7c9cff}
    .msg.user{background:#121b3c}
    .msg.ai{background:#0d1730}
    .meta{font-size:12px;color:var(--muted);margin-bottom:6px}
    .small{font-size:12px;color:var(--muted)}
    .kpi-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
    .kpi{padding:14px;border:1px solid var(--line);border-radius:16px;background:#0d1730}
    .kpi b{display:block;font-size:22px;margin-top:6px}
    .agent-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
    .onboarding{
      position:fixed;inset:0;background:rgba(3,7,18,.78);backdrop-filter:blur(8px);
      display:none;align-items:center;justify-content:center;z-index:1000;padding:18px
    }
    .onboarding.show{display:flex}
    .onboarding-card{
      width:min(980px, 100%);background:linear-gradient(180deg, rgba(17,25,54,.98), rgba(11,18,37,.98));
      border:1px solid var(--line);border-radius:26px;box-shadow:var(--shadow);padding:24px
    }
    .goal-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:14px}
    .goal{padding:14px;border:1px solid var(--line);border-radius:16px;background:#0d1730;cursor:pointer}
    .goal.active{outline:2px solid #7c9cff}
    @media (max-width: 1350px){ .layout{grid-template-columns:280px 1fr} .right-rail{grid-column:1 / -1} }
    @media (max-width: 980px){ .layout{grid-template-columns:1fr} .module-grid,.kpi-grid,.row,.agent-grid,.goal-grid{grid-template-columns:1fr} }
  /* PUBLIC BRAND POLISH SWEEP */
.public-shell{display:grid;gap:16px;margin-top:18px}
.public-hero,.public-card,.pricing-grid .plan-card,.dashboard-welcome{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:18px;
  padding:18px;
}
.public-hero h1{margin:0 0 8px 0;font-size:30px;line-height:1.1}
.public-hero .tag{display:inline-block;padding:6px 10px;border-radius:999px;background:rgba(255,255,255,.08);font-size:12px;margin-bottom:12px}
.public-grid,.pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px}
.plan-card .price{font-size:28px;font-weight:800;margin:8px 0}
.muted{opacity:.8}
.inline-note{font-size:12px;opacity:.75}
/* COGNITIVE LAB SWEEP */
.cog-grid,.plan-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px}
.cog-card,.plan-panel-card{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:18px;
  padding:16px;
}
.cog-kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px}
.cog-kpi{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:14px;
  padding:12px;
}
/* CELESTIAL COGNITIVE LAB UI SWEEP */
.celestial-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px}
.celestial-card{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:18px;
  padding:16px;
}
.celestial-kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px}
.celestial-kpi{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:14px;
  padding:12px;
}
</style>
</head>
<body>
<div class="onboarding" id="onboardingModal">
  <div class="onboarding-card">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap">
      <div>
        <h2 style="margin:0">Welcome to SemantiqAI Ascension</h2>
        <div class="small" style="margin-top:6px">Pick your mode so the machine knows which gears to spin first.</div>
      </div>
      <button class="secondary" style="width:auto" onclick="closeOnboarding()">Skip for now</button>
    </div>

    <div class="goal-grid">
      <div class="goal" data-goal="founder" onclick="pickGoal(this, 'founder')"><b>Founder OS</b><div class="small" style="margin-top:6px">Priorities, ops, launch rhythm</div></div>
      <div class="goal" data-goal="product" onclick="pickGoal(this, 'product')"><b>Product Build</b><div class="small" style="margin-top:6px">Features, UX, roadmap, systems</div></div>
      <div class="goal" data-goal="content" onclick="pickGoal(this, 'content')"><b>Content Engine</b><div class="small" style="margin-top:6px">Messaging, posts, assets, launch copy</div></div>
      <div class="goal" data-goal="research" onclick="pickGoal(this, 'research')"><b>Research</b><div class="small" style="margin-top:6px">Analysis, evidence, opportunity mapping</div></div>
      <div class="goal" data-goal="expansion" onclick="pickGoal(this, 'expansion')"><b>Expansion</b><div class="small" style="margin-top:6px">Scale, roadmap leverage, unfair growth</div></div>
      <div class="goal" data-goal="general" onclick="pickGoal(this, 'general')"><b>General AI Workspace</b><div class="small" style="margin-top:6px">Flexible mode with full control</div></div>
    </div>

    <div class="row" style="margin-top:16px">
      <select id="onboardingMode">
        <option value="solo">Solo SemantiqAI</option>
        <option value="council">Agent Council Mode</option>
      </select>
      <button class="primary" onclick="finishOnboarding()">Finish Onboarding</button>
    </div>

    <div class="starter-grid" id="starterCards" style="margin-top:16px"></div>
  </div>
</div>

<div class="shell">
  <div class="topbar">
    <div class="brand">
      <div class="logo">S</div>
      <div>
        <h1>SemantiqAI Ascension Agent Council</h1>
        <p>AIBrain Strategist • Content Generator • Founder OS • Research Architect • Expansion Planner</p>
      </div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
      <div class="pill" id="statusText">Checking status...</div>
      <div class="pill" id="userBadge">Guest</div>
    </div>
  </div>

  <div class="layout">
    <aside class="card">
      <div class="inner stack">
        <div>
          <h3 style="margin:0 0 6px">Access + Threads</h3>
          <div class="small">Now with guided entry instead of blank-screen poker face.</div>
        </div>

        <input id="username" placeholder="Username" />
        <input id="password" type="password" placeholder="Password" />

        <div class="row">
          <button class="primary" onclick="signup()">Sign up</button>
          <button class="secondary" onclick="login()">Log in</button>
        </div>
        <div class="row">
          <button class="secondary" onclick="loadMe()">Refresh Me</button>
          <button class="danger" onclick="logout()">Log out</button>
        </div>

        <div class="item">
          <div class="small">Role</div>
          <div id="roleText">guest</div>
        </div>

        <div class="row">
          <button class="primary" onclick="createThread()">New Thread</button>
          <button class="secondary" onclick="loadThreads()">Refresh Threads</button>
        </div>

        <div class="thread-list" id="threadList"></div>
      </div>
    </aside>

    <main class="card">
      <div class="hero">
        <h2>Agent council orchestration layer</h2>
        <p>
          You now have multiple specialist minds inside the same workspace, plus onboarding that helps new users pick a lane instead of staring into the void.
        </p>
        <div class="module-grid">
          <div class="mini">AIBrain Strategist</div>
          <div class="mini">Content Generator</div>
          <div class="mini">Founder OS</div>
          <div class="mini">Research Architect</div>
          <div class="mini">Expansion Planner</div>
          <div class="mini">Council Synthesis</div>
        </div>
      </div>

      <div class="tabs">
        <button class="tab active" data-tab="chat" onclick="showTab('chat', this)">Chat</button>
        <button class="tab" data-tab="council" onclick="showTab('council', this)">Agent Council</button>
        <button class="tab" data-tab="workflow" onclick="showTab('workflow', this)">Workflow</button>
        <button class="tab" data-tab="artifacts" onclick="showTab('artifacts', this)">Artifacts</button>
        <button class="tab" data-tab="knowledge" onclick="showTab('knowledge', this)">Knowledge</button>
        <button class="tab" data-tab="presets" onclick="showTab('presets', this)">Presets</button>
        <button class="tab" data-tab="feedback" onclick="showTab('feedback', this)">Feedback</button>`r`n        <button class="tab" data-tab="memory" onclick="showTab('memory', this)">Memory</button>`r`n        <button class="tab" data-tab="studio" onclick="showTab('studio', this)">Studio</button>
        <button class="tab" data-tab="jobs" onclick="showTab('jobs', this)">Jobs</button>`r`n        <button class="tab" data-tab="founder" onclick="showTab('founder', this)">Founder</button>
      </div>

      <section class="panel active" id="tab-chat">
        <div class="stack">
          <div class="row">
            <select id="chatPreset"></select>
            <button class="secondary" onclick="loadMessages()">Refresh Messages</button>
          </div>
          <div class="chat-log" id="chatLog"></div>
          <textarea id="chatMessage" placeholder="Ask SemantiqAI anything from strategy to product design to content planning..."></textarea>
          <div class="row">
            <button class="primary" onclick="sendChat()">Send Chat</button>
            <button class="secondary" onclick="generateArtifact()">Generate Artifact</button>
          </div>
        </div>
      </section>

      <section class="panel" id="tab-council">
        <div class="stack">
          <div class="agent-grid" id="agentGrid"></div>
          <textarea id="councilMessage" placeholder="Ask the agent council for a combined response. Example: design the next unfair growth roadmap for SemantiqAI with founder ops, content, research, and expansion strategy."></textarea>
          <div class="row">
            <button class="primary" onclick="runCouncil()">Run Agent Council</button>
            <button class="secondary" onclick="loadAgentRuns()">Load Agent Runs</button>
          </div>
          <div class="list" id="councilOutput"></div>
        </div>
      </section>

      <section class="panel" id="tab-workflow">
        <div class="stack">
          <div class="row">
            <select id="workflowPreset"></select>
            <button class="secondary" onclick="runPresetQuick()">Run Selected Preset</button>
          </div>
          <textarea id="workflowMessage" placeholder="Describe the workflow you want, such as a founder operating model, content engine, research structure, or expansion roadmap."></textarea>
          <div class="row">
            <button class="primary" onclick="runWorkflow()">Run Workflow</button>
            <button class="secondary" onclick="runPlan()">Plan Only</button>
          </div>
          <div class="list"><div class="item" id="workflowOutput" style="white-space:pre-wrap"></div></div>
        </div>
      </section>

      <section class="panel" id="tab-artifacts">
        <div class="stack">
          <div class="row">
            <button class="primary" onclick="loadArtifacts()">Load Artifacts</button>
            <button class="secondary" onclick="loadExports()">Load Exports</button>
          </div>
          <div class="list" id="artifactList"></div>
        </div>
      </section>

      <section class="panel" id="tab-knowledge">
        <div class="stack">
          <input id="knowledgeTitle" placeholder="Knowledge title" />
          <input id="knowledgeTags" placeholder="Tags comma-separated" />
          <textarea id="knowledgeContent" placeholder="Store doctrine, prompts, brand rules, onboarding notes, or operating knowledge here."></textarea>
          <div class="row">
            <button class="primary" onclick="saveKnowledge()">Save Knowledge</button>
            <button class="secondary" onclick="loadKnowledge()">Load Knowledge</button>
          </div>
          <div class="list" id="knowledgeList"></div>
        </div>
      </section>

      <section class="panel" id="tab-presets">
        <div class="stack">
          <div class="item">
            <div class="small">Create custom preset</div>
            <input id="presetTitle" placeholder="Preset title" style="margin-top:10px" />
            <input id="presetCategory" placeholder="Category" style="margin-top:10px" />
            <input id="presetDescription" placeholder="Short description" style="margin-top:10px" />
            <textarea id="presetTemplate" placeholder="Prompt template. Use {{input}} where the user request should go." style="margin-top:10px"></textarea>
            <div class="row" style="margin-top:10px">
              <button class="primary" onclick="savePreset()">Save Preset</button>
              <button class="secondary" onclick="loadPresets()">Load Presets</button>
            </div>
          </div>
          <div class="list" id="presetList"></div>
        </div>
      </section>

      <section class="panel" id="tab-feedback">
        <div class="stack">
          <select id="feedbackRating">
            <option value="up">Thumbs Up</option>
            <option value="down">Thumbs Down</option>
            <option value="idea">Idea</option>
            <option value="bug">Bug</option>
          </select>
          <textarea id="feedbackNote" placeholder="What worked, what broke, what should become unfairly good next?"></textarea>
          <div class="row">
            <button class="primary" onclick="sendFeedback()">Send Feedback</button>
            <button class="secondary" onclick="loadFeedback()">Founder Feedback Inbox</button>
          </div>
          <div class="list" id="feedbackList"></div>
        </div>
      </section>

            <section class="panel" id="tab-memory">
        <div class="stack">
          <div class="row">
            <input id="memoryTitle" placeholder="Memory title" />
            <input id="memoryTags" placeholder="Tags comma-separated" />
          </div>
          <textarea id="memoryContent" placeholder="Save important memory, user preference, strategic note, adaptive hint, or persistent context here..."></textarea>
          <div class="row">
            <button class="primary" onclick="saveMemory()">Save Memory</button>
            <button class="secondary" onclick="loadMemory()">Load Memory</button>
          </div>
          <div class="row">
            <input id="memorySearchQuery" placeholder="Search memory..." />
            <button class="secondary" onclick="searchMemory()">Search</button>
          </div>
          <div class="item">
            <div class="small">User Profile</div>
            <textarea id="profileGoals" placeholder='Goals, comma-separated' style="margin-top:10px"></textarea>
            <textarea id="profilePreferences" placeholder='Preferences, comma-separated' style="margin-top:10px"></textarea>
            <textarea id="profileTraits" placeholder='Traits, comma-separated' style="margin-top:10px"></textarea>
            <div class="row" style="margin-top:10px">
              <button class="primary" onclick="saveProfile()">Save Profile</button>
              <button class="secondary" onclick="loadProfile()">Load Profile</button>
            </div>
          </div>
          <div class="list" id="memoryList"></div>
        </div>
      </section>
      <section class="panel" id="tab-studio">
        <div class="stack">
          <div class="item">
            <div class="small">Streaming chat</div>
            <textarea id="streamMessage" placeholder="Type a prompt for streaming output..."></textarea>
            <div class="row" style="margin-top:10px">
              <button class="primary" onclick="startStreaming()">Start Stream</button>
              <button class="secondary" onclick="document.getElementById('streamOutput').textContent=''">Clear</button>
            </div>
            <div class="item" id="streamOutput" style="white-space:pre-wrap;margin-top:10px"></div>
          </div>

          <div class="item">
            <div class="small">CSV upload + analysis</div>
            <input type="file" id="csvFile" accept=".csv" style="margin-top:10px" />
            <div class="row" style="margin-top:10px">
              <button class="primary" onclick="uploadCsv()">Upload CSV</button>
              <button class="secondary" onclick="document.getElementById('csvAnalysis').innerHTML=''">Clear</button>
            </div>
            <div class="list" id="csvAnalysis" style="margin-top:10px"></div>
          </div>

          <div class="item">
            <div class="small">Exports + share</div>
            <div class="row" style="margin-top:10px">
              <button class="primary" onclick="loadExportsRich()">Load Exports</button>
              <button class="secondary" onclick="document.getElementById('exportsRich').innerHTML=''">Clear</button>
            </div>
            <div class="list" id="exportsRich" style="margin-top:10px"></div>
          </div>
        </div>
      </section>
<section class="panel" id="tab-founder">
        <div class="stack">
          <div class="item">
            <b>Founder Command Center</b>
            <div class="small" style="margin-top:8px">Steer users, memory, leads, moderation, launch posture, and system visibility from one throne panel.</div>
          </div>

          <div class="kpi-grid">
            <div class="kpi"><span class="small">Users</span><b id="kpiUsers">-</b></div>
            <div class="kpi"><span class="small">Threads</span><b id="kpiThreads">-</b></div>
            <div class="kpi"><span class="small">Messages</span><b id="kpiMessages">-</b></div>
            <div class="kpi"><span class="small">Artifacts</span><b id="kpiArtifacts">-</b></div>
            <div class="kpi"><span class="small">Knowledge</span><b id="kpiKnowledge">-</b></div>
            <div class="kpi"><span class="small">Agent Runs</span><b id="kpiAgentRuns">-</b></div>
            <div class="kpi"><span class="small">Leads</span><b id="kpiLeads">-</b></div>
            <div class="kpi"><span class="small">Memories</span><b id="kpiMemories">-</b></div>
            <div class="kpi"><span class="small">Notes</span><b id="kpiFounderNotes">-</b></div>
            <div class="kpi"><span class="small">Mod Actions</span><b id="kpiModActions">-</b></div>
          </div>

          <div class="row">
            <button class="primary" onclick="loadFounderCommandCenter()">Command Center</button>
            <button class="secondary" onclick="loadFounderUsers()">Users</button>
            <button class="secondary" onclick="loadFounderLeads()">Leads</button>
            <button class="secondary" onclick="loadFounderMemories()">Memory</button>
            <button class="secondary" onclick="loadFounderThreads()">Threads</button>
          </div>

          <div class="row">
            <button class="secondary" onclick="loadFounderNotes()">Notes</button>
            <button class="secondary" onclick="loadFounderModeration()">Moderation</button>
            <button class="secondary" onclick="loadFounderStats()">Legacy Stats</button>
            <button class="secondary" onclick="loadAnalytics()">Analytics</button>
          </div>

          <div class="row">
            <button class="secondary" onclick="loadDiagnostics()">Diagnostics</button>
            <button class="secondary" onclick="loadLaunchChecklist()">Launch Checklist</button>
            <button class="secondary" onclick="loadFounderRequestLogs()">Request Logs</button><button class="secondary" onclick="loadFounderSecurity()">Security</button>
            <button class="secondary" onclick="makeBackup()">Make Backup</button>
          </div>

          <div class="item">
            <div class="small" style="margin-bottom:8px">Founder note dropbox</div>
            <input id="founderNoteTitle" placeholder="Founder note title" />
            <textarea id="founderNoteContent" placeholder="Write ops notes, launch tasks, moderation rationale, or strategic reminders." style="margin-top:10px"></textarea>
            <button class="primary" style="margin-top:10px" onclick="saveFounderNote()">Save Founder Note</button>
          </div>

          <div class="list" id="founderList"></div>
        </div>
      </section>
    <section class="panel" id="tab-public">
  <div class="stack">
    <div class="public-shell" id="publicShell">
      <div class="public-hero">
        <div class="tag">SemantiqAI Ascension</div>
        <h1 id="publicHeroTitle">Think deeper. Build faster. Launch smarter.</h1>
        <div class="muted" id="publicHeroBody">Loading public site content...</div>
        <div class="row" style="margin-top:14px">
          <button class="primary" onclick="scrollToPublicBlock('publicWaitlist')">Join Waitlist</button>
          <button class="secondary" onclick="showTab('chat')">Enter App</button>
        </div>
