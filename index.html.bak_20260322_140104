<script>
const API = {
  token(){ return localStorage.getItem('sem_token') || ''; },
  setToken(t){ localStorage.setItem('sem_token', t); },
  clearToken(){ localStorage.removeItem('sem_token'); },
  headers(){
    const h = {'Content-Type':'application/json'};
    const t = this.token();
    if (t) h['Authorization'] = 'Bearer ' + t;
    return h;
  },
  async get(path){
    const r = await fetch(path, {headers:this.headers()});
    return await r.json();
  },
  async post(path, body){
    const r = await fetch(path, {method:'POST', headers:this.headers(), body:JSON.stringify(body || {})});
    return await r.json();
  },
  async del(path){
    const r = await fetch(path, {method:'DELETE', headers:this.headers()});
    return await r.json();
  }
};

let currentUser = null;
let currentThreadId = null;
let presetItems = [];
let agentItems = [];
let onboardingGoal = '';
let onboardingState = null;

function escapeHtml(s){
  return String(s ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}

function showTab(name, el){
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  if (el) el.classList.add('active');
}

function setUser(user){
  currentUser = user || null;
  document.getElementById('userBadge').textContent = user ? `${user.username} • ${user.role}` : 'Guest';
  document.getElementById('roleText').textContent = user ? user.role : 'guest';
  document.getElementById('appModeText').textContent = user ? `Logged in as ${user.username}` : 'Ready';
}

function setCurrentThread(thread){
  currentThreadId = thread ? thread.id : null;
  document.getElementById('currentThreadText').textContent = thread ? thread.title : 'none';
}

function presetOptions(){
  return ['<option value="">No preset</option>'].concat(
    presetItems.map(p => `<option value="${escapeHtml(p.preset_key)}">${escapeHtml(p.category)} • ${escapeHtml(p.title)}</option>`)
  ).join('');
}

async function healthCheck(){
  try{
    const s = await API.get('/status');
    document.getElementById('statusText').textContent = `${s.app || 'SemantiqAI'} • ${s.version || ''} • ${s.stage || ''}`;
  }catch{
    document.getElementById('statusText').textContent = 'Backend unreachable';
  }
  try{
    const cfg = await API.get('/config/public');
    document.getElementById('brandModulesText').textContent = (cfg.brand_modules || []).join(' • ');
  }catch{
    document.getElementById('brandModulesText').textContent = 'unavailable';
  }
}

async function signup(){
  const username = document.getElementById('username').value.trim();
  const password = document.getElementById('password').value;
  const d = await API.post('/signup', {username, password});
  if (d.token){
    API.setToken(d.token);
    setUser(d.user);
    await afterLoginLoad();
  } else alert(d.error || 'Signup failed');
}

async function login(){
  const username = document.getElementById('username').value.trim();
  const password = document.getElementById('password').value;
  const d = await API.post('/login', {username, password});
  if (d.token){
    API.setToken(d.token);
    setUser(d.user);
    await afterLoginLoad();
  } else alert(d.error || 'Login failed');
}

async function afterLoginLoad(){
  await loadThreads();
  await loadPresets();
  await loadAgents();
  await loadOnboarding();
    loadPublicSite().catch(() => {});
    loadDashboardWelcome().catch(() => {});
    loadCognitiveDashboard().catch(() => {});
    if (currentUser && (currentUser.role === 'founder' || currentUser.role === 'admin')) { loadFounderCommandCenter().catch(() => {}); }
}

function logout(){
  API.clearToken();
  currentUser = null;
  currentThreadId = null;
  setUser(null);
  setCurrentThread(null);
  document.getElementById('threadList').innerHTML = '';
  document.getElementById('chatLog').innerHTML = '';
  closeOnboarding();
}

async function loadMe(){
  try{
    const d = await API.get('/me');
    if (d.user) setUser(d.user);
  }catch{}
}

async function createThread(){
  const title = prompt('Thread title:', 'New Thread');
  if (!title) return;
  const d = await API.post('/threads', {title});
  if (d.thread){
    await loadThreads();
    await openThread(d.thread.id);
  }
}

async function loadThreads(){
  const d = await API.get('/threads');
  const items = d.items || [];
  const el = document.getElementById('threadList');
  el.innerHTML = items.map(t => `
    <div class="thread-item ${t.id === currentThreadId ? 'active' : ''}">
      <div><b>${escapeHtml(t.title)}</b></div>
      <div class="small" style="margin-top:6px">${escapeHtml(t.updated_at || '')}${t.is_archived ? ' • archived' : ''}</div>
      <div class="row" style="margin-top:10px">
        <button class="secondary" onclick="openThread(${t.id})">Open</button>
        <button class="secondary" onclick="renameThread(${t.id})">Rename</button>
      </div>
      <div class="row" style="margin-top:8px">
        <button class="secondary" onclick="archiveThread(${t.id})">Archive</button>
        <button class="danger" onclick="deleteThread(${t.id})">Delete</button>
      </div>
    </div>
  `).join('') || '<div class="item">No threads yet.</div>';

  if (!currentThreadId && items.length){
    await openThread(items[0].id);
  }
}

async function openThread(id){
  const d = await API.get(`/threads/${id}/messages`);
  setCurrentThread(d.thread);
  const log = document.getElementById('chatLog');
  log.innerHTML = (d.items || []).map(m => `
    <div class="msg ${m.role === 'user' ? 'user' : 'ai'}">
      <div class="meta">${escapeHtml(m.role)}${m.agent ? ' • ' + escapeHtml(m.agent) : ''} • ${escapeHtml(m.created_at || '')}</div>
      <div>${escapeHtml(m.content || '')}</div>
    </div>
  `).join('') || '<div class="item">No messages yet.</div>';
  await loadThreads();
}

async function loadMessages(){
  if (!currentThreadId) return;
  await openThread(currentThreadId);
}

async function renameThread(id){
  const title = prompt('New thread title:');
  if (!title) return;
  await API.post(`/threads/${id}/rename`, {title});
  await loadThreads();
  if (currentThreadId === id) await openThread(id);
}

async function archiveThread(id){
  await API.post(`/threads/${id}/archive`, {});
  await loadThreads();
}

async function deleteThread(id){
  if (!confirm('Delete this thread and its messages/artifacts?')) return;
  await API.del(`/threads/${id}`);
  currentThreadId = null;
  await loadThreads();
  document.getElementById('chatLog').innerHTML = '';
}

async function loadPresets(){
  const d = await API.get('/presets');
  presetItems = d.items || [];
  document.getElementById('chatPreset').innerHTML = presetOptions();
  document.getElementById('workflowPreset').innerHTML = presetOptions();
  document.getElementById('presetList').innerHTML = presetItems.map(p => `
    <div class="item">
      <div><b>${escapeHtml(p.title)}</b></div>
      <div class="small">${escapeHtml(p.category || '')} • ${p.is_system ? 'system' : 'custom'}</div>
      <div style="margin-top:8px">${escapeHtml(p.description || '')}</div>
