  const prompt_template = document.getElementById('presetTemplate').value.trim();
  const d = await API.post('/presets', {title, category, description, prompt_template});
  if (d.error) return alert(d.error);
  document.getElementById('presetTitle').value = '';
  document.getElementById('presetCategory').value = '';
  document.getElementById('presetDescription').value = '';
  document.getElementById('presetTemplate').value = '';
